{
    "name": "@wiz-sh/formatter",
    "version": "0.1.0",
    "description": "Lossless, deterministic formatter and minifier for Wiz shell source",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/wiz-sh/linter.git",
        "directory": "packages/formatter"
    },
    "type": "module",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.js",
            "default": "./dist/index.js"
        }
    },
    "files": [
        "dist"
    ],
    "scripts": {
        "build": "bun build ./src/index.ts --outdir ./dist --target bun --format esm && tsc --project ./tsconfig.build.json"
    },
    "dependencies": {
        "@wiz-sh/compiler": "^0.1.0"
    },
    "publishConfig": {
        "access": "public"
    },
    "engines": {
        "bun": ">=1.2.0"
    }
}
